{
  "_comment": "VRChat 实时翻译流 配置文件。敏感 API Key 建议写入系统环境变量，在 params 中用 dollar+{变量名} 格式引用。",
  "_comment_modules": [
    "全局模块注册表：所有模块（音频源、翻译、消费者）统一在此以 ref_id 为键定义。",
    "Pipeline 的 graph 仅描述拓扑连接，不内联任何参数。",
    "同一 ref_id 可被多条 pipeline 引用，引擎为每条 pipeline 独立实例化。"
  ],
  "modules": {
    "_comment_audio": "── 音频源模块 ──────────────────────────────────────────",
    "流式音频": {
      "type": "loopback",
      "params": {
        "process_name": "VRChat.exe",
        "sample_rate": 16000,
        "vad_mode": 3,
        "mode": "streaming",
        "chunk_ms": 200
      },
      "display_name": "流式音频"
    },
    "流式麦克风": {
      "type": "microphone",
      "params": {
        "sample_rate": 16000,
        "vad_mode": 3,
        "mode": "streaming",
        "chunk_ms": 200
      },
      "display_name": "流式麦克风"
    },
    "分句音频": {
      "type": "loopback",
      "params": {
        "process_name": "VRChat.exe",
        "sample_rate": 16000,
        "vad_mode": 3,
        "mode": "batch",
        "chunk_ms": 200
      },
      "display_name": "分句音频"
    },
    "分句麦克风": {
      "type": "microphone",
      "params": {
        "sample_rate": 16000,
        "vad_mode": 3,
        "mode": "batch",
        "max_segment_seconds": 30.0,
        "chunk_ms": 200,
        "sync_vrc_mic": false
      },
      "display_name": "分句麦克风"
    },
    "_comment_stt": "── 语音识别模块 ─────────────────────────────────────────",
    "流式识别-本地": {
      "_comment": [
        "本地 FunASR Paraformer 流式语音识别，无需网络和 API Key。",
        "依赖安装：pip install funasr",
        "model_path 填写本地模型目录的绝对路径，示例模型：",
        "  speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-online（中文）",
        "streaming_mode=true 时需搭配音频源 mode=\"streaming\"，每 600ms 出一次中间结果。",
        "streaming_mode=false 时搭配音频源 mode=\"batch\"，语音段结束后一次性输出最终结果。",
        "输出包字段与 volc_streaming_stt 完全一致，可接同一套下游模块（MT/Filter/OSC等）。"
      ],
      "type": "local_stt",
      "params": {
        "model_path": ".models\\paraformer",
        "model_name": "paraformer-zh-streaming",
        "streaming_mode": true,
        "chunk_size": [
          0,
          10,
          5
        ],
        "encoder_chunk_look_back": 4,
        "decoder_chunk_look_back": 1
      },
      "display_name": "流式识别-本地"
    },
    "分句识别-本地": {
      "type": "local_stt",
      "params": {
        "model_path": "models\\SenseVoiceSmall",
        "model_name": "iic/SenseVoiceSmall",
        "streaming_mode": false
      },
      "display_name": "分句识别-本地"
    },
    "流式识别-火山豆包API": {
      "type": "volc_streaming_stt",
      "params": {
        "_comment": "新版控制台用 api_key（UUID），旧版控制台改用 app_id + access_key",
        "api_key": "${VOLC_API_KEY}",
        "resource_id": "volc.seedasr.sauc.duration",
        "language": "",
        "streaming_mode": true
      },
      "display_name": "流式识别-火山豆包API"
    },
    "_comment_mt": "── 机器翻译模块 ─────────────────────────────────────────",
    "翻译到英文-火山豆包API": {
      "type": "volc_machine_translation",
      "params": {
        "_comment": "新版控制台用 api_key（UUID）；旧版改用 app_id + access_key",
        "api_key": "${VOLC_API_KEY}",
        "source_language": "",
        "target_language": "en"
      },
      "display_name": "翻译到英文-火山豆包API"
    },
    "翻译到日文-火山豆包API": {
      "type": "volc_machine_translation",
      "params": {
        "api_key": "${VOLC_API_KEY}",
        "source_language": "",
        "target_language": "ja"
      },
      "display_name": "翻译到日文-火山豆包API"
    },
    "翻译到英文-百度翻译API": {
      "type": "baidu_machine_translation",
      "params": {
        "app_id": "${BAIDU_APP_ID}",
        "app_key": "${BAIDU_APP_KEY}",
        "source_language": "auto",
        "target_language": "en"
      },
      "display_name": "翻译到英文-百度翻译API"
    },
    "翻译到日文-百度翻译API": {
      "type": "baidu_machine_translation",
      "params": {
        "app_id": "${BAIDU_APP_ID}",
        "app_key": "${BAIDU_APP_KEY}",
        "source_language": "auto",
        "target_language": "jp"
      },
      "display_name": "翻译到日文-百度翻译API"
    },
    "_comment_consumer": "── 消费者模块 ───────────────────────────────────────────",
    "软件日志输出": {
      "type": "terminal",
      "params": {
        "color": true,
        "_comment_grouping": "group_by 指向两条翻译分支的公共祖先节点时间戳。收到新包立即渲染，同一时间戳的包合并显示，新时间戳丢弃旧内容。"
      },
      "display_name": "软件日志输出"
    },
    "VRChat输出": {
      "type": "osc_vrchat",
      "params": {
        "host": "127.0.0.1",
        "port": 9000,
        "trigger_sfx": false,
        "group_by": "timestamp_中间件-GUI输入文字"
      },
      "display_name": "VRChat输出"
    },
    "_comment_filter": "── 中间件模块 ─────────────────────────────────────────",
    "中间件-完整句子过滤器": {
      "type": "filter",
      "params": {
        "_comment": "只放行最终识别结果（is_partial=false），中间流式包被丢弃，不进入翻译环节",
        "field": "is_partial",
        "pass_when": false
      },
      "display_name": "中间件-完整句子过滤器"
    },
    "中间件-GUI输入文字": {
      "type": "text_input",
      "params": {
        "source_lang": "auto"
      },
      "display_name": "中间件-GUI输入文字"
    },
    "翻译到中文-百度翻译API": {
      "type": "baidu_machine_translation",
      "params": {
        "app_id": "${BAIDU_APP_ID}",
        "app_key": "${BAIDU_APP_KEY}",
        "source_language": "auto",
        "target_language": "zh"
      },
      "display_name": "翻译到中文-百度翻译API"
    },
    "mod_82a2acacfaa354f5": {
      "display_name": "大语言翻译模块（需要密钥）",
      "type": "llm_openai_api_call",
      "params": {
        "target_language": "to_en_jp",
        "api_url": "https://ark.cn-beijing.volces.com/api/v3/responses",
        "headers_b64": "ewogICJBdXRob3JpemF0aW9uIjogIkJlYXJlciAke2xsbV9hcGlfa2V5fSIsCiAgIkNvbnRlbnQtVHlwZSI6ICJhcHBsaWNhdGlvbi9qc29uIgp9",
        "payload_b64": ""
      }
    }
  },
